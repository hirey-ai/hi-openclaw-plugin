{
  "name": "hirey",
  "version": "1.0.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/hirey-ai/hi-openclaw-plugin.git"
  },
  "homepage": "https://github.com/hirey-ai/hi-openclaw-plugin#readme",
  "license": "UNLICENSED",
  "description": "Hirey Hi as a native OpenClaw plugin: registers Hi tools, the agent-events claim service, and webhook ingress directly inside the gateway process \u2014 zero independent daemons, no `mcp.servers.hi` indirection, no per-run frozen tool inventory boundary. Same business logic as @hirey/hi-mcp-server / @hirey/hi-agent-receiver, but wired through OpenClaw's native register(api) instead of stdio MCP + spawned daemon. For OpenClaw 5.x; pre-5.x users keep using the ClawHub bundle path.",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "1.0"
    },
    "build": {
      "openclawVersion": "2026.5.6"
    },
    "install": {
      "minHostVersion": ">=2026.4.23"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsx --test src/**/*.test.ts",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.4"
  },
  "dependencies": {
    "@hirey/hi-agent-contracts": "^0.1.15",
    "@hirey/hi-agent-sdk": "^0.1.10"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "openclaw": "2026.5.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}